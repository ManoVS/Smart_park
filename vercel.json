{
  "version": 3,
  "functions": {
    "backend/app.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/generate_ticket",
      "dest": "/backend/app.py"
    },
    {
      "src": "/generate_qr/(.*)",
      "dest": "/backend/app.py"
    },
    {
      "src": "/dashboard",
      "dest": "/backend/app.py"
    },
    {
      "src": "/health",
      "dest": "/backend/app.py"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}

